# ── DG-LAB WebSocket 服务 ──
DGLAB_WS_PORT=9999
HEARTBEAT_INTERVAL=60000
DEFAULT_PUNISHMENT_TIME=1
DEFAULT_PUNISHMENT_DURATION=5

# ── Electron 内部 HTTP API ──
APP_API_PORT=9998

# ── 日志 ──
LOG_LEVEL=info

# ── 可选：B站账号 SESSDATA（填写后弹幕用户名不打码）──
# 获取：浏览器打开 bilibili.com → F12 → Application → Cookies → SESSDATA
# BILI_SESSDATA=

# ── 可选：手动指定 buvid3（通常自动获取，无需填写）──
# BILI_BUVID3=
