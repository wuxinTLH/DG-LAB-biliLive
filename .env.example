# ── DG-LAB WebSocket 服务 ──
DGLAB_WS_PORT=9999
HEARTBEAT_INTERVAL=60000
DEFAULT_PUNISHMENT_TIME=1
DEFAULT_PUNISHMENT_DURATION=5

# ── Electron 内部 HTTP API ──
APP_API_PORT=9998

# ── 日志 ──
LOG_LEVEL=info

# ── 可选：B站账号 SESSDATA（填写后可获取未打码的弹幕用户名）──
# 从浏览器 F12 → Application → Cookies → bilibili.com → SESSDATA 复制
BILI_SESSDATA=
BILI_ACCESS_KEY_ID=
BILI_ACCESS_KEY_SECRET=
BILI_APP_ID=